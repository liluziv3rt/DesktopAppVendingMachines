<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAppVendingMachines.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DesktopAppVendingMachines.Views.AddVendingMachineView"
             x:DataType="vm:AddVendingMachineViewModel">

    <Grid Background="#F5F7FA" Margin="20">
        <ScrollViewer>
            <StackPanel Spacing="20">
                <TextBlock Text="Создание торгового автомата" 
                           FontSize="28" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <Border Background="White" CornerRadius="16" Padding="20" BoxShadow="0 4 12 #14000000">
                    <Grid ColumnDefinitions="1*, 1*" ColumnSpacing="30">
                        <StackPanel Grid.Column="0" Spacing="15">
                            <StackPanel>
                                <TextBlock Text="Название ТА *" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding Name}" Watermark="Введите название"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="1*, 1*" ColumnSpacing="10">
                                <StackPanel>
                                    <TextBlock Text="Производитель ТА *" FontSize="14" Foreground="#2C3E50"/>
                                    <ComboBox ItemsSource="{Binding Manufactures}"
                                              SelectedItem="{Binding SelectedManufacture}"
                                              DisplayMemberBinding="{Binding Name}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Модель ТА *" FontSize="14" Foreground="#2C3E50"/>
                                    <ComboBox ItemsSource="{Binding Models}"
                                              SelectedItem="{Binding SelectedModel}"
                                              DisplayMemberBinding="{Binding Model1}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel>
                                <TextBlock Text="Режим работы *" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding WorkModes}" 
                                          SelectedItem="{Binding SelectedWorkMode}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Адрес *" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding Location}" Watermark="Введите адрес"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Место *" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Places}" 
                                          SelectedItem="{Binding SelectedPlace}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Координаты" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding Coordinates}" Watermark="54.5191,36.2802"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="1*, 1*" ColumnSpacing="10">
                                <StackPanel>
                                    <TextBlock Text="Номер автомата *" FontSize="14" Foreground="#2C3E50"/>
                                    <TextBox Text="{Binding SerialNumber}" Watermark="Номер"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Время работы" FontSize="14" Foreground="#2C3E50"/>
                                    <TextBox Text="{Binding WorkingHours}" Watermark="08:00-22:00"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel>
                                <TextBlock Text="Часовой пояс *" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Timezones}" 
                                          SelectedItem="{Binding SelectedTimezone}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Шаблон крит. значений" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding CriticalThresholdTemplates}" 
                                          SelectedItem="{Binding SelectedCriticalThresholdTemplate}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Шаблон уведомлений" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding NotificationTemplates}" 
                                          SelectedItem="{Binding SelectedNotificationTemplate}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="15">
                            <StackPanel>
                                <TextBlock Text="Клиент" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Clients}"
                                          SelectedItem="{Binding SelectedClient}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Family}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Менеджер" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Managers}"
                                          SelectedItem="{Binding SelectedManager}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Family}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Инженер" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Engineers}"
                                          SelectedItem="{Binding SelectedEngineer}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Family}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Техник-оператор" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Technicians}"
                                          SelectedItem="{Binding SelectedTechnician}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Family}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Платежные системы *" FontSize="14" Foreground="#2C3E50"/>
                                <CheckBox Content="Монетоприемник" IsChecked="{Binding CoinAcceptorEnabled}"/>
                                <CheckBox Content="Купюроприемник" IsChecked="{Binding BillAcceptorEnabled}"/>
                                <CheckBox Content="Модуль б/н оплаты" IsChecked="{Binding CashlessModuleEnabled}"/>
                                <CheckBox Content="QR-платежи" IsChecked="{Binding QrPaymentsEnabled}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="RFID карты обслуживания" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding RfidService}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="RFID карты инкассации" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding RfidCashCollection}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="RFID карты загрузки" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding RfidLoading}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Id кассы Kit Online" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding KitOnlineId}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Приоритет обслуживания *" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding ServicePriorities}" 
                                          SelectedItem="{Binding SelectedServicePriority}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Модем *" FontSize="14" Foreground="#2C3E50"/>
                                <ComboBox ItemsSource="{Binding Modems}" 
                                          SelectedItem="{Binding SelectedModem}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Примечания" FontSize="14" Foreground="#2C3E50"/>
                                <TextBox Text="{Binding Notes}" AcceptsReturn="True" Height="80" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}"
                            Background="#27AE60" Foreground="White" Padding="20 10" CornerRadius="5"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}"
                            Background="#E74C3C" Foreground="White" Padding="20 10" CornerRadius="5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>