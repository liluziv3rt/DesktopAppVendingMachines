<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAppVendingMachines.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DesktopAppVendingMachines.Views.MainView"
             x:DataType="vm:MainViewModel">
    
    <Grid ColumnDefinitions="280, *">
        <!-- Левое меню -->
        <Border Grid.Column="0" Background="#1E2A3A">
            <StackPanel Margin="25" Spacing="20">
                <!-- Логотип -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Background="#3498DB" Width="45" Height="45" CornerRadius="8">
                        <TextBlock Text="🍬" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VendingApp" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Блок пользователя -->
                <Border Background="#2C3E50" CornerRadius="12" Padding="20">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" 
                                Width="60" Height="60" CornerRadius="30" 
                                Background="#3498DB" Margin="0 0 15 0"
                                ClipToBounds="True">
                            <Image Source="{Binding UserPhotoPath}" 
                                   Width="60" Height="60" 
                                   Stretch="UniformToFill"/>
                        </Border>
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                   Text="{Binding UserName}" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                   Text="Администратор" 
                                   Foreground="#BDC3C7" 
                                   FontSize="14"
                                   VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Навигационное меню -->
                <StackPanel Spacing="8">
                    <Button Content="🏠 Главная" 
                            Background="#3498DB" 
                            Foreground="White" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Left"
                            Padding="20 12"
                            CornerRadius="8"
                            BorderThickness="0"/>
                    <Button Content="📊 Монитор ТА" 
                            Background="Transparent" 
                            Foreground="#BDC3C7" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Left"
                            Padding="20 12"
                            CornerRadius="8"
                            BorderThickness="0"/>
                    <Button Content="📈 Детальные отчеты" 
                            Background="Transparent" 
                            Foreground="#BDC3C7" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Left"
                            Padding="20 12"
                            CornerRadius="8"
                            BorderThickness="0"/>
                    <Button Content="📦 Учет ТМЦ" 
                            Background="Transparent" 
                            Foreground="#BDC3C7" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Left"
                            Padding="20 12"
                            CornerRadius="8"
                            BorderThickness="0"/>
                    <Button Content="⚙️ Администрирование" 
                            Background="Transparent" 
                            Foreground="#BDC3C7" 
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Left"
                            Padding="20 12"
                            CornerRadius="8"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Кнопка выхода -->
                <Button Content="🚪 Выход" 
                        Background="Transparent" 
                        Foreground="#E74C3C" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Left"
                        Padding="20 12"
                        CornerRadius="8"
                        BorderThickness="0"
                        Margin="0 20 0 0"/>
            </StackPanel>
        </Border>

        <!-- Основная область -->
        <ScrollViewer Grid.Column="1" Background="#F5F7FA">
            <StackPanel Margin="30" Spacing="30">
                <!-- Заголовок -->
                <TextBlock Text="Личный кабинет. Главная" 
                           FontSize="30" 
                           FontWeight="SemiBold" 
                           Foreground="#2C3E50"/>

                <!-- Блок эффективности сети (два сектора) -->
                <Border Background="White" 
                        CornerRadius="16" 
                        Padding="30"
                        BoxShadow="0 4 12 #14000000">
                    <StackPanel>
                        <TextBlock Text="Эффективность сети" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0 0 0 20"/>
                        <lvc:PieChart
                            Series="{Binding EfficiencySeries}"
                            Height="250"
                            TooltipPosition="Top"
                            LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <!-- Блок состояния сети (три сектора) -->
                <Border Background="White" 
                        CornerRadius="16" 
                        Padding="30"
                        BoxShadow="0 4 12 #14000000">
                    <StackPanel>
                        <TextBlock Text="Состояние сети" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0 0 0 20"/>
                        <lvc:PieChart
                            Series="{Binding StateSeries}"
                            Height="250"
                            TooltipPosition="Top"
                            LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <!-- Динамика продаж (график) -->
                <Border Background="White" 
                        CornerRadius="16" 
                        Padding="30"
                        BoxShadow="0 4 12 #14000000">
                    <StackPanel>
                        <TextBlock Text="Динамика продаж за последние 10 дней" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"/>
                        <TextBlock Text="Данные по продажам с 01.03.2025 по 10.03.2025" 
                                   FontSize="13" 
                                   Foreground="#7F8C8D" 
                                   Margin="0 5 0 15"/>

                        <!-- Кнопки переключения -->
                        <Grid ColumnDefinitions="Auto, Auto, *" Margin="0 0 0 20">
                            <Button Grid.Column="0" 
                                    Content="По сумме" 
                                    Background="{Binding IsSumMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#3498DB,#BDC3C7'}"
                                    Foreground="White"
                                    Padding="20 10"
                                    CornerRadius="8 0 0 8"
                                    Command="{Binding ShowSumCommand}"/>
                            <Button Grid.Column="1" 
                                    Content="По количеству" 
                                    Background="{Binding IsSumMode, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#BDC3C7,#3498DB'}"
                                    Foreground="White"
                                    Padding="20 10"
                                    CornerRadius="0 8 8 0"
                                    Command="{Binding ShowQuantityCommand}"/>
                        </Grid>

                        <lvc:CartesianChart
                            Series="{Binding SalesSeries}"
                            XAxes="{Binding XAxes}"
                            Height="300"
                            TooltipPosition="Top"
                            LegendPosition="Hidden"/>
                    </StackPanel>
                </Border>

                <!-- Сводка (заглушка) -->
                <Border Background="White" 
                        CornerRadius="16" 
                        Padding="30"
                        BoxShadow="0 4 12 #14000000">
                    <StackPanel>
                        <TextBlock Text="Сводка" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0 0 0 20"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20">
                            <Border Background="#F8F9F9" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Денег в ТА" Foreground="#7F8C8D" FontSize="15"/>
                                    <TextBlock Text="27 959 ₽" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F8F9F9" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Сдача в ТА" Foreground="#7F8C8D" FontSize="15"/>
                                    <TextBlock Text="12 729 ₽" FontSize="28" FontWeight="Bold" Foreground="#2C3E50"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F8F9F9" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Выручка сегодня" Foreground="#7F8C8D" FontSize="15"/>
                                    <TextBlock Text="11 870 ₽" FontSize="28" FontWeight="Bold" Foreground="#27AE60"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Новости (заглушка) -->
                <Border Background="White" 
                        CornerRadius="16" 
                        Padding="30"
                        BoxShadow="0 4 12 #14000000">
                    <StackPanel>
                        <TextBlock Text="Новости" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0 0 0 20"/>
                        <StackPanel Spacing="10">
                            <Border Background="#F0F7FF" CornerRadius="8" Padding="15">
                                <TextBlock Text="• Терминалы КЗРи получают экзайнер от Cobra" Foreground="#2C3E50" FontSize="15"/>
                            </Border>
                            <Border Background="#F0F7FF" CornerRadius="8" Padding="15">
                                <TextBlock Text="• Релиз новой CRM-системы KIT Shop" Foreground="#2C3E50" FontSize="15"/>
                            </Border>
                            <Border Background="#FFF4E6" CornerRadius="8" Padding="15">
                                <TextBlock Text="• Ставки НДС 35% и 7% для УСН" Foreground="#2C3E50" FontSize="15"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>