<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DesktopAppVendingMachines.ViewModels"
             xmlns:views="using:DesktopAppVendingMachines.Views"
             xmlns:converters="using:DesktopAppVendingMachines.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DesktopAppVendingMachines.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Grid RowDefinitions="70, 50, *" ColumnDefinitions="280, *">
        
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="White" 
                BoxShadow="0 2 8 #1A000000"
                Padding="20 0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Assets/Logo.png" 
                           Width="160" Height="60" 
                           Stretch="Fill"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" Text=""/>
                
                <Border Grid.Column="2" 
                        Background="#F5F7FA" 
                        CornerRadius="30" 
                        Padding="10 5"
                        VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="10">
                        <Border Grid.Column="0" 
                                Width="40" Height="40" 
                                CornerRadius="20" 
                                Background="#3498DB"
                                ClipToBounds="True">
                            <Image Source="/Assets/Flag.png" 
                                   Width="40" Height="40" 
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" 
                                       Foreground="#2C3E50" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UserRole}" 
                                       Foreground="#7F8C8D" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Background="#1E2A3A">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0" Spacing="0">
                    
                    <TextBlock Text="Навигация" 
                               FontSize="12" 
                               FontWeight="SemiBold"
                               Foreground="#BDC3C7" 
                               Margin="25 20 0 10"/>

                    <StackPanel Spacing="0">
                        <Button Content="🏠 Главная" 
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Main"
                                Background="Transparent"
                                Foreground="White" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left" 
                                Padding="25 12" 
                                CornerRadius="0" 
                                BorderThickness="0"/>
                        
                        <Button Content="📊 Монитор ТА" 
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Monitor"
                                Background="Transparent"
                                Foreground="White" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left" 
                                Padding="25 12" 
                                CornerRadius="0" 
                                BorderThickness="0"/>
                        
                        <Button Content="📈 Детальные отчеты" 
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Reports"
                                Background="Transparent"
                                Foreground="White" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left" 
                                Padding="25 12" 
                                CornerRadius="0" 
                                BorderThickness="0"/>
                        
                        <Button Content="📦 Учет ТМЦ" 
                                Command="{Binding NavigateToCommand}"
                                CommandParameter="Inventory"
                                Background="Transparent"
                                Foreground="White" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left" 
                                Padding="25 12" 
                                CornerRadius="0" 
                                BorderThickness="0"/>
                        
                        <Expander Header="⚙️ Администрирование" 
                                  Background="Transparent"
                                  BorderThickness="0"
                                  IsExpanded="{Binding IsAdminMenuExpanded}"
                                  Padding="25 12">
                            <Expander.Styles>
                                <Style Selector="Expander">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                                <Style Selector="Expander /template/ ToggleButton">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Style>
                                <Style Selector="Expander /template/ Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </Expander.Styles>
                            <Expander.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="⚙️ Администрирование" 
                                               Foreground="White"
                                               FontSize="14"/>
                                </DataTemplate>
                            </Expander.HeaderTemplate>
                            <StackPanel Margin="25 5 0 10" Spacing="5">
                                
                                <Button Content="📋 Торговые автоматы" 
                                        Command="{Binding NavigateToCommand}"
                                        CommandParameter="VendingMachines"
                                        Background="Transparent"
                                        Foreground="White" 
                                        HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left" 
                                        Padding="15 8" 
                                        CornerRadius="0" 
                                        BorderThickness="0"
                                        FontSize="13"/>
                                
                                <Button Content="🏢 Компании" 
                                        Command="{Binding NavigateToCommand}"
                                        CommandParameter="Companies"
                                        Background="Transparent"
                                        Foreground="White" 
                                        HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left" 
                                        Padding="15 8" 
                                        CornerRadius="0" 
                                        BorderThickness="0"
                                        FontSize="13"/>
                                
                                <Button Content="👥 Пользователи" 
                                        Command="{Binding NavigateToCommand}"
                                        CommandParameter="Users"
                                        Background="Transparent"
                                        Foreground="White" 
                                        HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left" 
                                        Padding="15 8" 
                                        CornerRadius="0" 
                                        BorderThickness="0"
                                        FontSize="13"/>
                                
                                <Button Content="📡 Модемы" 
                                        Command="{Binding NavigateToCommand}"
                                        CommandParameter="Modems"
                                        Background="Transparent"
                                        Foreground="White" 
                                        HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left" 
                                        Padding="15 8" 
                                        CornerRadius="0" 
                                        BorderThickness="0"
                                        FontSize="13"/>
                                
                                <Button Content="➕ Дополнительные" 
                                        Command="{Binding NavigateToCommand}"
                                        CommandParameter="Additional"
                                        Background="Transparent"
                                        Foreground="White" 
                                        HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left" 
                                        Padding="15 8" 
                                        CornerRadius="0" 
                                        BorderThickness="0"
                                        FontSize="13"/>
                            </StackPanel>
                        </Expander>
                        
                        <Button Content="🚪 Выход" 
                                Command="{Binding LogoutCommand}"
                                Background="Transparent" 
                                Foreground="#E74C3C" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left" 
                                Padding="25 12" 
                                CornerRadius="0" 
                                BorderThickness="0" 
                                Margin="0 20 0 0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#2C3E50" Padding="20 0">
            <Grid ColumnDefinitions="Auto, *">
                <TextBlock Text="ООО Торговые Автоматы" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="White" 
                           VerticalAlignment="Center"/>
                
                <TextBlock Grid.Column="1" 
                           Text="{Binding CurrentPageTitle}" 
                           FontSize="14"
                           Foreground="#BDC3C7" 
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.Column="1" Background="#F5F7FA">
            <views:MainViewContent IsVisible="{Binding CurrentPage, Converter={StaticResource IsNull}}"/>
            
            <ContentControl Content="{Binding CurrentPage}"
                            IsVisible="{Binding CurrentPage, Converter={StaticResource IsNotNull}}"/>
        </Grid>
    </Grid>
</UserControl>