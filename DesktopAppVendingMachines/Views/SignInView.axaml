<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:DesktopAppVendingMachines.ViewModels"
             x:Class="DesktopAppVendingMachines.Views.SignInView"
             x:DataType="vm:SignInViewModel">

              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
        <TextBlock Text="Авторизация" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   TextAlignment="Center" 
                   Margin="0 0 0 20"/>

        <TextBlock Text="Логин (Email)" Margin="0 5 0 0"/>
        <TextBox Text="{Binding Email}" Watermark="Введите email"/>

        <TextBlock Text="Пароль" Margin="0 10 0 0"/>
        <TextBox Text="{Binding Password}" 
                 PasswordChar="*" 
                 Watermark="Введите пароль"/>

        <Button Content="Войти" 
                HorizontalAlignment="Center" 
                Margin="0 20 0 0" 
                Command="{Binding EnterCommand}"/>

        <Button Content="Регистрация" 
                HorizontalAlignment="Center" 
                Margin="0 10 0 0" 
                Command="{Binding GoToSignUpCommand}"
                Background="LightBlue"/>

        <TextBlock Text="{Binding Message}" 
                   Foreground="Red" 
                   TextWrapping="Wrap"
                   Margin="0 10 0 0"/>
    </StackPanel>
            
</UserControl>
