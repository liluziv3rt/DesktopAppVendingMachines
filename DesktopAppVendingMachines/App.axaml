<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="DesktopAppVendingMachines.App"
             xmlns:local="using:DesktopAppVendingMachines"
             xmlns:converters="using:DesktopAppVendingMachines.Converters"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <converters:PageToColorConverter x:Key="PageToColorConverter"/>
        <converters:IsNullConverter x:Key="IsNull"/>
        <converters:IsNotNullConverter x:Key="IsNotNull"/>
        <converters:IsGreaterThanOneConverter x:Key="IsGreaterThanOne"/>
        <converters:IsLessThanTotalPagesConverter x:Key="IsLessThanTotalPages"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
         <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
    </Application.Styles>
</Application>