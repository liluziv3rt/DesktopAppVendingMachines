<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="VendingApp.Views.SignInView"
             xmlns:vm="using:VendingApp.ViewModels"
             x:DataType="vm:SignInViewModel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
				<TextBlock Text="Логин" TextAlignment="Center"/>
                <TextBox Text="{Binding Login}"/>

                <TextBlock Text="Пароль" TextAlignment="Center" Margin="0 10 0 0"/>
                <TextBox Text="{Binding Password}" PasswordChar="*"/>

                <Button Content="Войти" HorizontalAlignment="Center" Margin="0 10 0 0" Command="{Binding Enter}"/>

                <TextBlock Text="{Binding Message}" Foreground="Red"/>
            </StackPanel>
</UserControl>
